  "private": true,
  "license": "Apache-2.0",
  "description": "Interactive CLI for the Sereno shielded remittance corridor (Midnight)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "demo": "node dist/demo.js",
    "demo-sim": "node dist/demo-sim.js",
    "agent": "node dist/agent.js",
    "agent:demo": "node dist/agent.js --demo",
    "smoke": "node dist/smoke-local.js",
