{
  "name": "sereno-contract",
  "version": "0.1.0",
  "description": "Sereno: shielded remittance corridor with selective auditor disclosure (Midnight Compact contract)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "compact": "compact compile src/sereno.compact src/managed/sereno",
    "typecheck": "tsc --noEmit",
    "build": "npm run compact && tsc && npm run copy-managed",
    "copy-managed": "node -e \"import('node:fs').then(fs => fs.cpSync('src/managed', 'dist/managed', { recursive: true }))\""
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.16.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
